#!/bin/bash

# 1. Die Kanone feuern (rsync)
rsync -aHAXxv --delete --numeric-ids /home/beute/ rockvm@10.10.10.25:/home/beute/

# 2. Prüfen, ob die Ladung erfolgreich war (Exit-Code 0)
if [ $? -eq 0 ]; then
    echo "Beute ist sicher auf der Rocky-VM!"
    logger "LADUNG: Erfolgreich! Beute ist sicher auf Rocky."
else
    echo "FEHLER! rsync ist fehlgeschlagen!"
    logger "LADUNG-BACKUP: rsync ist fehlgeschlagen!"
fi
